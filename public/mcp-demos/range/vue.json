{"slug":"range","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Range Slider\" back-link></f7-navbar>\n\n    <f7-block-title>Volume</f7-block-title>\n    <f7-list simple-list strong inset>\n      <f7-list-item>\n        <div>\n          <f7-icon ios=\"f7:speaker_fill\" md=\"material:volume_mute\" />\n        </div>\n        <div style=\"width: 100%; margin: 0 16px\">\n          <f7-range :min=\"0\" :max=\"100\" :step=\"1\" :value=\"10\" />\n        </div>\n        <div>\n          <f7-icon ios=\"f7:speaker_3_fill\" md=\"material:volume_up\" />\n        </div>\n      </f7-list-item>\n    </f7-list>\n\n    <f7-block-title>Brightness</f7-block-title>\n    <f7-list simple-list strong inset>\n      <f7-list-item>\n        <div>\n          <f7-icon ios=\"f7:sun_min\" md=\"material:brightness_low\" />\n        </div>\n        <div style=\"width: 100%; margin: 0 16px\">\n          <f7-range :min=\"0\" :max=\"100\" :step=\"1\" :value=\"50\" :label=\"true\" color=\"orange\" />\n        </div>\n        <div>\n          <f7-icon ios=\"f7:sun_max_fill\" md=\"material:brightness_high\" />\n        </div>\n      </f7-list-item>\n    </f7-list>\n\n    <f7-block-title class=\"display-flex justify-content-space-between\"\n      >Price Filter <span>${{ priceMin }} - ${{ priceMax }}</span></f7-block-title\n    >\n    <f7-list simple-list strong inset>\n      <f7-list-item>\n        <div>\n          <f7-icon ios=\"f7:money_dollar_circle\" md=\"material:attach_money\" />\n        </div>\n        <div style=\"width: 100%; margin: 0 16px\">\n          <f7-range\n            :min=\"0\"\n            :max=\"500\"\n            :step=\"1\"\n            :value=\"[priceMin, priceMax]\"\n            :label=\"true\"\n            :dual=\"true\"\n            color=\"green\"\n            @range:change=\"onPriceChange\"\n          />\n        </div>\n        <div>\n          <f7-icon ios=\"f7:money_dollar_circle_fill\" md=\"material:monetization_on\" />\n        </div>\n      </f7-list-item>\n    </f7-list>\n\n    <f7-block-title>With Scale</f7-block-title>\n    <f7-block strong inset>\n      <f7-range\n        :min=\"0\"\n        :max=\"100\"\n        :label=\"true\"\n        :step=\"5\"\n        :value=\"25\"\n        :scale=\"true\"\n        :scale-steps=\"5\"\n        :scale-sub-steps=\"4\"\n      />\n    </f7-block>\n\n    <f7-block-title>Vertical</f7-block-title>\n    <f7-block strong inset class=\"display-flex justify-content-center\">\n      <f7-range\n        class=\"margin-right\"\n        style=\"height: 160px\"\n        :vertical=\"true\"\n        :min=\"0\"\n        :max=\"100\"\n        :label=\"true\"\n        :step=\"1\"\n        :value=\"25\"\n      />\n      <f7-range\n        class=\"margin-horizontal\"\n        style=\"height: 160px\"\n        :vertical=\"true\"\n        :min=\"0\"\n        :max=\"100\"\n        :label=\"true\"\n        :step=\"1\"\n        :value=\"50\"\n      />\n      <f7-range\n        class=\"margin-horizontal\"\n        style=\"height: 160px\"\n        :vertical=\"true\"\n        :min=\"0\"\n        :max=\"100\"\n        :label=\"true\"\n        :step=\"1\"\n        :value=\"75\"\n      />\n      <f7-range\n        class=\"margin-left\"\n        style=\"height: 160px\"\n        :dual=\"true\"\n        :vertical=\"true\"\n        :min=\"0\"\n        :max=\"100\"\n        :label=\"true\"\n        :step=\"1\"\n        :value=\"[25, 75]\"\n      />\n    </f7-block>\n\n    <f7-block-title>Vertical Reversed</f7-block-title>\n    <f7-block strong inset class=\"display-flex justify-content-center\">\n      <f7-range\n        class=\"margin-right\"\n        color=\"red\"\n        style=\"height: 160px\"\n        :vertical=\"true\"\n        :vertical-reversed=\"true\"\n        :min=\"0\"\n        :max=\"100\"\n        :label=\"true\"\n        :step=\"1\"\n        :value=\"25\"\n      />\n      <f7-range\n        class=\"margin-horizontal\"\n        color=\"red\"\n        style=\"height: 160px\"\n        :vertical=\"true\"\n        :vertical-reversed=\"true\"\n        :min=\"0\"\n        :max=\"100\"\n        :label=\"true\"\n        :step=\"1\"\n        :value=\"50\"\n      />\n      <f7-range\n        class=\"margin-horizontal\"\n        color=\"red\"\n        style=\"height: 160px\"\n        :vertical=\"true\"\n        :vertical-reversed=\"true\"\n        :min=\"0\"\n        :max=\"100\"\n        :label=\"true\"\n        :step=\"1\"\n        :value=\"75\"\n      />\n      <f7-range\n        class=\"margin-left\"\n        color=\"red\"\n        style=\"height: 160px\"\n        :dual=\"true\"\n        :vertical=\"true\"\n        :vertical-reversed=\"true\"\n        :min=\"0\"\n        :max=\"100\"\n        :label=\"true\"\n        :step=\"1\"\n        :value=\"[25, 75]\"\n      />\n    </f7-block>\n  </f7-page>\n</template>\n<script>\nimport {\n  f7Navbar,\n  f7Page,\n  f7BlockTitle,\n  f7Range,\n  f7List,\n  f7ListItem,\n  f7Icon,\n  f7Block,\n} from 'framework7-vue';\n\nexport default {\n  components: { f7Navbar, f7Page, f7BlockTitle, f7Range, f7List, f7ListItem, f7Icon, f7Block },\n  data() {\n    return { priceMin: 200, priceMax: 400 };\n  },\n  methods: {\n    onPriceChange(values) {\n      this.priceMin = values[0];\n      this.priceMax = values[1];\n    },\n  },\n};\n</script>\n"}