{"slug":"data-table-head-inputs","framework":"core","source":"<template>\n  <div id=\"app\">\n    <div class=\"view view-main view-init\">\n      <!-- source start -->\n      <div class=\"page\">\n        <div class=\"navbar\">\n          <div class=\"navbar-bg\"></div>\n          <div class=\"navbar-inner\">\n            <div class=\"title\">Data Table</div>\n          </div>\n        </div>\n        <div class=\"page-content\">\n          <div class=\"card data-table\">\n            <table>\n              <thead>\n                <tr>\n                  <th class=\"input-cell\">\n                    <span class=\"table-head-label\">ID</span>\n                    <div class=\"input\" style=\"width: 50px\">\n                      <input type=\"number\" placeholder=\"Filter\" />\n                    </div>\n                  </th>\n                  <th class=\"input-cell\">\n                    <span class=\"table-head-label\">Name</span>\n                    <div class=\"input\">\n                      <input type=\"text\" placeholder=\"Filter\" />\n                    </div>\n                  </th>\n                  <th class=\"input-cell\">\n                    <span class=\"table-head-label\">Email</span>\n                    <div class=\"input\">\n                      <input type=\"email\" placeholder=\"Filter\" />\n                    </div>\n                  </th>\n                  <th class=\"input-cell\">\n                    <span class=\"table-head-label\">Gender</span>\n                    <div class=\"input input-dropdown\">\n                      <select>\n                        <option value=\"All\">All</option>\n                        <option value=\"Male\">Male</option>\n                        <option value=\"Female\">Female</option>\n                      </select>\n                    </div>\n                  </th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr>\n                  <td>1</td>\n                  <td>John Doe</td>\n                  <td>john@doe.com</td>\n                  <td>Male</td>\n                </tr>\n                <tr>\n                  <td>2</td>\n                  <td>Jane Doe</td>\n                  <td>jane@doe.com</td>\n                  <td>Female</td>\n                </tr>\n                <tr>\n                  <td>3</td>\n                  <td>Vladimir Kharlampidi</td>\n                  <td>vladimir@google.com</td>\n                  <td>Male</td>\n                </tr>\n                <tr>\n                  <td>4</td>\n                  <td>Jennifer Doe</td>\n                  <td>jennifer@doe.com</td>\n                  <td>Female</td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n      </div>\n      <!-- source end -->\n    </div>\n  </div>\n</template>"}