button button-outline button-active\" href=\"#\">Button 1</a>\n              <a class=\"button button-outline\" href=\"#\">Button 2</a>\n              <a class=\"button button-outline\" href=\"#\">Button\n                3</a>\n            </p>\n            <p>\n              <a class=\"button button-large button-fill\" href=\"#\">Fill Button</a>\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n"}