{"slug":"toggle","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Toggle\" back-link></f7-navbar>\n    <f7-block-title>Super Heroes</f7-block-title>\n    <f7-list simple-list strong inset dividers-ios>\n      <f7-list-item>\n        <span>Batman</span>\n        <f7-toggle checked></f7-toggle>\n      </f7-list-item>\n      <f7-list-item>\n        <span>Aquaman</span>\n        <f7-toggle checked color=\"blue\"></f7-toggle>\n      </f7-list-item>\n      <f7-list-item>\n        <span>Superman</span>\n        <f7-toggle checked color=\"red\"></f7-toggle>\n      </f7-list-item>\n      <f7-list-item>\n        <span>Hulk</span>\n        <f7-toggle color=\"green\"></f7-toggle>\n      </f7-list-item>\n      <f7-list-item>\n        <span>Spiderman (Disabled)</span>\n        <f7-toggle disabled></f7-toggle>\n      </f7-list-item>\n      <f7-list-item>\n        <span>Ironman (Disabled)</span>\n        <f7-toggle checked disabled></f7-toggle>\n      </f7-list-item>\n      <f7-list-item>\n        <span>Thor</span>\n        <f7-toggle checked color=\"orange\"></f7-toggle>\n      </f7-list-item>\n      <f7-list-item>\n        <span>Wonder Woman</span>\n        <f7-toggle color=\"pink\"></f7-toggle>\n      </f7-list-item>\n    </f7-list>\n  </f7-page>\n</template>\n<script>\nimport { f7Navbar, f7Page, f7BlockTitle, f7List, f7ListItem, f7Toggle } from 'framework7-vue';\n\nexport default { components: { f7Navbar, f7Page, f7BlockTitle, f7List, f7ListItem, f7Toggle } };\n</script>\n"}