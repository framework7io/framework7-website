{"slug":"toggle","framework":"react","source":"import React from 'react';\nimport { Navbar, Page, BlockTitle, List, ListItem, Toggle } from 'framework7-react';\n\nexport default () => (\n  <Page>\n    <Navbar title=\"Toggle\" backLink></Navbar>\n    <BlockTitle>Super Heroes</BlockTitle>\n    <List simpleList strong inset dividersIos>\n      <ListItem>\n        <span>Batman</span>\n        <Toggle defaultChecked />\n      </ListItem>\n      <ListItem>\n        <span>Aquaman</span>\n        <Toggle defaultChecked color=\"blue\" />\n      </ListItem>\n      <ListItem>\n        <span>Superman</span>\n        <Toggle defaultChecked color=\"red\" />\n      </ListItem>\n      <ListItem>\n        <span>Hulk</span>\n        <Toggle color=\"green\" />\n      </ListItem>\n      <ListItem>\n        <span>Spiderman (Disabled)</span>\n        <Toggle disabled />\n      </ListItem>\n      <ListItem>\n        <span>Ironman (Disabled)</span>\n        <Toggle defaultChecked disabled />\n      </ListItem>\n      <ListItem>\n        <span>Thor</span>\n        <Toggle defaultChecked color=\"orange\" />\n      </ListItem>\n      <ListItem>\n        <span>Wonder Woman</span>\n        <Toggle color=\"pink\" />\n      </ListItem>\n    </List>\n  </Page>\n);\n"}