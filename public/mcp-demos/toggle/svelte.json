{"slug":"toggle","framework":"svelte","source":"<script>\n  import { Navbar, Page, BlockTitle, List, ListItem, Toggle } from 'framework7-svelte';\n</script>\n\n<Page>\n  <Navbar title=\"Toggle\" backLink />\n  <BlockTitle>Super Heroes</BlockTitle>\n  <List simpleList strong inset dividersIos>\n    <ListItem>\n      <span>Batman</span>\n      <Toggle checked />\n    </ListItem>\n    <ListItem>\n      <span>Aquaman</span>\n      <Toggle checked color=\"blue\" />\n    </ListItem>\n    <ListItem>\n      <span>Superman</span>\n      <Toggle checked color=\"red\" />\n    </ListItem>\n    <ListItem>\n      <span>Hulk</span>\n      <Toggle color=\"green\" />\n    </ListItem>\n    <ListItem>\n      <span>Spiderman (Disabled)</span>\n      <Toggle disabled />\n    </ListItem>\n    <ListItem>\n      <span>Ironman (Disabled)</span>\n      <Toggle checked disabled />\n    </ListItem>\n    <ListItem>\n      <span>Thor</span>\n      <Toggle checked color=\"orange\" />\n    </ListItem>\n    <ListItem>\n      <span>Wonder Woman</span>\n      <Toggle color=\"pink\" />\n    </ListItem>\n  </List>\n</Page>\n"}