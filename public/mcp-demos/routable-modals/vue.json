{"slug":"routable-modals","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Routable Modals\" back-link></f7-navbar>\n    <f7-block strong inset>\n      <p>In addition to pages, Framework7 router allows to load modal components:</p>\n    </f7-block>\n    <f7-list strong inset dividers-ios>\n      <f7-list-item title=\"Popup\" link=\"popup/\" />\n      <f7-list-item title=\"Action Sheet\" link=\"actions/\" />\n    </f7-list>\n  </f7-page>\n</template>\n<script>\nimport { f7Navbar, f7Page, f7List, f7ListItem, f7Block } from 'framework7-vue';\n\nexport default { components: { f7Navbar, f7Page, f7List, f7ListItem, f7Block } };\n</script>\n"}