{"slug":"toolbar-tabbar","framework":"core","source":"<template>\n  <div class=\"page\">\n    <div class=\"navbar\">\n      <div class=\"navbar-bg\"></div>\n      <div class=\"navbar-inner sliding\">\n        <div class=\"left\">\n          <a class=\"link back\">\n            <i class=\"icon icon-back\"></i>\n\n          </a>\n        </div>\n        <div class=\"title\">Toolbar & Tabbar</div>\n      </div>\n    </div>\n    <div class=\"toolbar toolbar-${toolbarPosition}\">\n      <div class=\"toolbar-inner\">\n        <div class=\"toolbar-pane\">\n          <a class=\"link\">Link 1</a>\n          <a class=\"link\">Link 2</a>\n        </div>\n        <div class=\"toolbar-pane\">\n          <a class=\"link\">Link 3</a>\n        </div>\n      </div>\n    </div>\n    <div class=\"page-content\">\n      <div class=\"list list-strong inset list-dividers-ios links-list\">\n        <ul>\n          <li>\n            <a href=\"./tabbar/\">Tabbar</a>\n          </li>\n          <li>\n            <a href=\"./tabbar-icons/\">Tabbar With Icons</a>\n          </li>\n          <li>\n            <a href=\"./tabbar-scrollable/\">Tabbar Scrollable</a>\n          </li>\n          <li>\n            <a href=\"./toolbar-hide-scroll/\">Hide Toolbar On Scroll</a>\n          </li>\n        </ul>\n      </div>\n      <div class=\"block-title\">Toolbar Position</div>\n      <div class=\"block block-strong inset\">\n        <p>Toolbar supports both top and bottom positions. Click the following button to change its position.</p>\n        <p><a class=\"button button-fill button-round\" @click=${toggleToolbarPosition}>Toggle Toolbar Position</a></p>\n      </div>\n    </div>\n  </div>\n</template>\n<script>\n  export default (props, { $update }) => {\n    let toolbarPosition = 'bottom';\n\n    const toggleToolbarPosition = () => {\n      toolbarPosition = toolbarPosition === 'top' ? 'bottom' : 'top';\n      $update();\n    }\n\n    return $render;\n  };\n</script>\n"}