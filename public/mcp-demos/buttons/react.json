{"slug":"buttons","framework":"react","source":"import React, { useState } from 'react';\nimport { Navbar, Page, BlockTitle, Block, Button } from 'framework7-react';\n\nexport default () => {\n  const [isLoading1, setIsLoading1] = useState(false);\n  const [isLoading2, setIsLoading2] = useState(false);\n\n  const load1 = () => {\n    if (isLoading1) return;\n    setIsLoading1(true);\n    setTimeout(() => {\n      setIsLoading1(false);\n    }, 4000);\n  };\n  const load2 = () => {\n    if (isLoading2) return;\n    setIsLoading2(true);\n    setTimeout(() => {\n      setIsLoading2(false);\n    }, 4000);\n  };\n\n  return (\n    <Page>\n      <Navbar title=\"Buttons\" backLink />\n\n      <BlockTitle>Usual Buttons</BlockTitle>\n      <Block strong inset>\n        <div className=\"grid grid-cols-3 grid-gap\">\n          <Button>Button</Button>\n          <Button>Button</Button>\n          <Button round>Round</Button>\n        </div>\n      </Block>\n\n      <BlockTitle>Tonal Buttons</BlockTitle>\n      <Block strong inset>\n        <div className=\"grid grid-cols-3 grid-gap\">\n          <Button tonal>Button</Button>\n          <Button tonal>Button</Button>\n          <Button tonal round>\n            Round\n          </Button>\n        </div>\n      </Block>\n\n      <BlockTitle>Fill Buttons</BlockTitle>\n      <Block strong inset>\n        <div className=\"grid grid-cols-3 grid-gap\">\n          <Button fill>Button</Button>\n          <Button fill>Button</Button>\n          <Button fill round>\n            Round\n          </Button>\n        </div>\n      </Block>\n\n      <BlockTitle>Outline Buttons</BlockTitle>\n      <Block strong inset>\n        <div className=\"grid grid-cols-3 grid-gap\">\n          <Button outline>Button</Button>\n          <Button outline>Button</Button>\n          <Button outline round>\n            Round\n          </Button>\n        </div>\n      </Block>\n\n      <BlockTitle>Raised Buttons</BlockTitle>\n      <Block strong inset>\n        <p className=\"grid grid-cols-3 grid-gap\">\n          <Button raised>Button</Button>\n          <Button raised fill>\n            Fill\n          </Button>\n          <Button raised outline>\n            Outline\n          </Button>\n        </p>\n        <p className=\"grid grid-cols-3 grid-gap\">\n          <Button raised round>\n            Round\n          </Button>\n          <Button raised fill round>\n            Fill\n          </Button>\n          <Button raised outline round>\n            Outline\n          </Button>\n        </p>\n      </Block>\n\n      <BlockTitle>Large Buttons</BlockTitle>\n      <Block strong inset>\n        <p className=\"grid grid-cols-2 grid-gap\">\n          <Button large>Button</Button>\n          <Button large fill>\n            Fill\n          </Button>\n        </p>\n        <p className=\"grid grid-cols-2 grid-gap\">\n          <Button large raised>\n            Raised\n          </Button>\n          <Button large raised fill>\n            Raised Fill\n          </Button>\n        </p>\n      </Block>\n\n      <BlockTitle>Small Buttons</BlockTitle>\n      <Block strong inset>\n        <p className=\"grid grid-cols-3 grid-gap\">\n          <Button small>Button</Button>\n          <Button small outline>\n            Outline\n          </Button>\n          <Button small fill>\n            Fill\n          </Button>\n        </p>\n        <p className=\"grid grid-cols-3 grid-gap\">\n          <Button small round>\n            Button\n          </Button>\n          <Button small outline round>\n            Outline\n          </Button>\n          <Button small fill round>\n            Fill\n          </Button>\n        </p>\n      </Block>\n\n      <BlockTitle>Preloader Buttons</BlockTitle>\n      <Block strong inset>\n        <p className=\"grid grid-cols-2 grid-gap\">\n          <Button preloader loading={isLoading1} onClick={load1} large>\n            Load\n          </Button>\n          <Button preloader loading={isLoading2} onClick={load2} large fill>\n            Load\n          </Button>\n        </p>\n      </Block>\n\n      <BlockTitle>Color Buttons</BlockTitle>\n      <Block strong inset>\n        <div className=\"grid grid-cols-3 grid-gap\">\n          <Button color=\"red\">Red</Button>\n          <Button color=\"green\">Green</Button>\n          <Button color=\"blue\">Blue</Button>\n        </div>\n      </Block>\n\n      <BlockTitle>Color Fill Buttons</BlockTitle>\n      <Block strong inset>\n        <p className=\"grid grid-cols-3 grid-gap\">\n          <Button round fill color=\"red\">\n            Red\n          </Button>\n          <Button round fill color=\"green\">\n            Green\n          </Button>\n          <Button round fill color=\"blue\">\n            Blue\n          </Button>\n        </p>\n        <p className=\"grid grid-cols-3 grid-gap\">\n          <Button round fill color=\"pink\">\n            Pink\n          </Button>\n          <Button round fill color=\"yellow\">\n            Yellow\n          </Button>\n          <Button round fill color=\"orange\">\n            Orange\n          </Button>\n        </p>\n        <p className=\"grid grid-cols-3 grid-gap\">\n          <Button round fill color=\"black\">\n            Black\n          </Button>\n          <Button round fill color=\"white\">\n            White\n          </Button>\n        </p>\n      </Block>\n    </Page>\n  );\n};\n"}