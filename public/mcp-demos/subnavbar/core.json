{"slug":"subnavbar","framework":"core","source":"<div class=\"page page-with-subnavbar\">\n  <div class=\"navbar\">\n    <div class=\"navbar-bg\"></div>\n    <div class=\"navbar-inner sliding\">\n      <div class=\"left\">\n        <a class=\"link back\">\n          <i class=\"icon icon-back\"></i>\n\n        </a>\n      </div>\n      <div class=\"title\">Subnavbar</div>\n      <div class=\"subnavbar\">\n        <div class=\"subnavbar-inner\">\n          <div class=\"segmented segmented-strong segmented-round\">\n            <button class=\"button button-small-md button-round button-active\">Link 1</button>\n            <button class=\"button button-small-md button-round\">Link 2</button>\n            <button class=\"button button-small-md button-round\">Link 3</button>\n            <span class=\"segmented-highlight\"></span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n  <div class=\"page-content\">\n    <div class=\"block block-strong inset\">\n      <p>Subnavbar is useful when you need to put any additional elements into Navbar, like Tab Links or Search Bar. It\n        also remains visible when Navbar hidden.</p>\n    </div>\n    <div class=\"list list-strong inset links-list\">\n      <ul>\n        <li><a href=\"/subnavbar-title/\">Subnavbar Title</a></li>\n      </ul>\n    </div>\n  </div>\n</div>\n"}