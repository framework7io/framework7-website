{"slug":"list-button","framework":"core","source":"<template>\n  <div class=\"page\">\n    <div class=\"navbar\">\n      <div class=\"navbar-bg\"></div>\n      <div class=\"navbar-inner sliding\">\n        <div class=\"left\">\n          <a class=\"link back\">\n            <i class=\"icon icon-back\"></i>\n\n          </a>\n        </div>\n        <div class=\"title\">List Button</div>\n      </div>\n    </div>\n\n    <div class=\"page-content\">\n      <div class=\"list inset list-strong list-dividers-ios\">\n        <ul>\n          <li><a class=\"list-button\">List Button 1</a></li>\n          <li><a class=\"list-button\">List Button 2</a></li>\n          <li><a class=\"list-button\">List Button 2</a></li>\n        </ul>\n      </div>\n      <div class=\"list inset list-strong\">\n        <ul>\n          <li><a class=\"list-button color-red\">Large Red Button</a></li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</template>\n"}