{"slug":"color-picker","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Color Picker\" back-link></f7-navbar>\n\n    <f7-block strong inset>\n      <p>\n        Framework7 comes with ultimate modular Color Picker component that allows to create color\n        picker with limitless combinations of color modules.\n      </p>\n    </f7-block>\n\n    <f7-block-title>Color Wheel</f7-block-title>\n    <f7-block-header>Minimal example with color wheel in Popover</f7-block-header>\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"wheePickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{ targetEl: '.wheel-picker-target' }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${wheePickerValue.hex}`\"\n            class=\"icon demo-list-icon wheel-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Saturation-Brightness Spectrum</f7-block-title>\n    <f7-block-header>SB Spectrum + Hue Slider in Popover</f7-block-header>\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"spectrumPickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{\n          modules: ['sb-spectrum', 'hue-slider'],\n          targetEl: '.spectrum-picker-target',\n        }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${spectrumPickerValue.hex}`\"\n            class=\"icon demo-list-icon spectrum-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Hue-Saturation Spectrum</f7-block-title>\n    <f7-block-header>HS Spectrum + Brightness Slider in Popover</f7-block-header>\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"hsSpectrumPickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{\n          modules: ['hs-spectrum', 'brightness-slider'],\n          targetEl: '.hs-spectrum-picker-target',\n        }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${hsSpectrumPickerValue.hex}`\"\n            class=\"icon demo-list-icon hs-spectrum-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>RGB Sliders</f7-block-title>\n    <f7-block-header>RGB sliders with labels and values in Popover</f7-block-header>\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"rgbPickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{\n          modules: ['rgb-sliders'],\n          sliderValue: true,\n          sliderLabel: true,\n          targetEl: '.rgb-picker-target',\n        }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${rgbPickerValue.hex}`\"\n            class=\"icon demo-list-icon rgb-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>RGBA Sliders</f7-block-title>\n    <f7-block-header>RGB sliders + Alpha Slider with labels and values in Popover</f7-block-header>\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"rgbaPickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{\n          modules: ['rgb-sliders', 'alpha-slider'],\n          sliderValue: true,\n          sliderLabel: true,\n          targetEl: '.rgba-picker-target',\n          formatValue(value) {\n            return `rgba(${value.rgba.join(', ')})`;\n          },\n        }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${\n              rgbaPickerValue.rgba\n                ? `rgba(${rgbaPickerValue.rgba.join(', ')})`\n                : rgbaPickerValue.hex\n            }`\"\n            class=\"icon demo-list-icon rgba-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>HSB Sliders</f7-block-title>\n    <f7-block-header>HSB sliders with labels and values in Popover</f7-block-header>\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"hsbPickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{\n          modules: ['hsb-sliders'],\n          sliderValue: true,\n          sliderLabel: true,\n          targetEl: '.hsb-picker-target',\n          formatValue(value) {\n            return `hsb(${value.hsb[0]}, ${(value.hsb[1] * 1000) / 10}%, ${\n              (value.hsb[2] * 1000) / 10\n            }%)`;\n          },\n        }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${hsbPickerValue.hex}`\"\n            class=\"icon demo-list-icon hsb-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>RGB Bars</f7-block-title>\n    <f7-block-header\n      >RGB bars with labels and values in Popover on tablet and in Popup on phone</f7-block-header\n    >\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"rgbBarsPickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{\n          modules: ['rgb-bars'],\n          openIn: 'auto',\n          barValue: true,\n          barLabel: true,\n          targetEl: '.rgb-bars-picker-target',\n          formatValue(value) {\n            return `rgb(${value.rgb.join(', ')})`;\n          },\n        }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${rgbBarsPickerValue.hex}`\"\n            class=\"icon demo-list-icon rgb-bars-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>RGB Sliders + Colors</f7-block-title>\n    <f7-block-header\n      >RGB sliders with labels and values in Popover, and previous and current color values\n      blocks</f7-block-header\n    >\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"rgbSlidersColorsPickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{\n          modules: ['initial-current-colors', 'rgb-sliders'],\n          sliderValue: true,\n          sliderLabel: true,\n          targetEl: '.rgb-sliders-colors-picker-target',\n          formatValue(value) {\n            return `rgb(${value.rgb.join(', ')})`;\n          },\n        }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${rgbSlidersColorsPickerValue.hex}`\"\n            class=\"icon demo-list-icon rgb-sliders-colors-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Palette</f7-block-title>\n    <f7-block-header\n      >Palette opened in Sheet modal on phone and Popover on larger screens</f7-block-header\n    >\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"palettePickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{\n          modules: ['palette'],\n          openIn: 'auto',\n          openInPhone: 'sheet',\n          palette: [\n            [\n              '#FFEBEE',\n              '#FFCDD2',\n              '#EF9A9A',\n              '#E57373',\n              '#EF5350',\n              '#F44336',\n              '#E53935',\n              '#D32F2F',\n              '#C62828',\n              '#B71C1C',\n            ],\n            [\n              '#F3E5F5',\n              '#E1BEE7',\n              '#CE93D8',\n              '#BA68C8',\n              '#AB47BC',\n              '#9C27B0',\n              '#8E24AA',\n              '#7B1FA2',\n              '#6A1B9A',\n              '#4A148C',\n            ],\n            [\n              '#E8EAF6',\n              '#C5CAE9',\n              '#9FA8DA',\n              '#7986CB',\n              '#5C6BC0',\n              '#3F51B5',\n              '#3949AB',\n              '#303F9F',\n              '#283593',\n              '#1A237E',\n            ],\n            [\n              '#E1F5FE',\n              '#B3E5FC',\n              '#81D4FA',\n              '#4FC3F7',\n              '#29B6F6',\n              '#03A9F4',\n              '#039BE5',\n              '#0288D1',\n              '#0277BD',\n              '#01579B',\n            ],\n            [\n              '#E0F2F1',\n              '#B2DFDB',\n              '#80CBC4',\n              '#4DB6AC',\n              '#26A69A',\n              '#009688',\n              '#00897B',\n              '#00796B',\n              '#00695C',\n              '#004D40',\n            ],\n            [\n              '#F1F8E9',\n              '#DCEDC8',\n              '#C5E1A5',\n              '#AED581',\n              '#9CCC65',\n              '#8BC34A',\n              '#7CB342',\n              '#689F38',\n              '#558B2F',\n              '#33691E',\n            ],\n            [\n              '#FFFDE7',\n              '#FFF9C4',\n              '#FFF59D',\n              '#FFF176',\n              '#FFEE58',\n              '#FFEB3B',\n              '#FDD835',\n              '#FBC02D',\n              '#F9A825',\n              '#F57F17',\n            ],\n            [\n              '#FFF3E0',\n              '#FFE0B2',\n              '#FFCC80',\n              '#FFB74D',\n              '#FFA726',\n              '#FF9800',\n              '#FB8C00',\n              '#F57C00',\n              '#EF6C00',\n              '#E65100',\n            ],\n          ],\n          targetEl: '.palette-picker-target',\n          formatValue(value) {\n            return value.hex;\n          },\n        }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${palettePickerValue.hex}`\"\n            class=\"icon demo-list-icon palette-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Pro Mode</f7-block-title>\n    <f7-block-header\n      >Current Color + HSB Sliders + RGB sliders + Alpha Slider + HEX + Palette with labels and\n      editable values</f7-block-header\n    >\n    <f7-list strong inset>\n      <f7-list-input\n        v-model:value=\"proPickerValue\"\n        type=\"colorpicker\"\n        placeholder=\"Color\"\n        readonly\n        :color-picker-params=\"{\n          modules: [\n            'initial-current-colors',\n            'sb-spectrum',\n            'hsb-sliders',\n            'rgb-sliders',\n            'alpha-slider',\n            'hex',\n            'palette',\n          ],\n          openIn: 'auto',\n          sliderValue: true,\n          sliderValueEditable: true,\n          sliderLabel: true,\n          hexLabel: true,\n          hexValueEditable: true,\n          groupedModules: true,\n          palette: [\n            [\n              '#FFEBEE',\n              '#FFCDD2',\n              '#EF9A9A',\n              '#E57373',\n              '#EF5350',\n              '#F44336',\n              '#E53935',\n              '#D32F2F',\n              '#C62828',\n              '#B71C1C',\n            ],\n            [\n              '#F3E5F5',\n              '#E1BEE7',\n              '#CE93D8',\n              '#BA68C8',\n              '#AB47BC',\n              '#9C27B0',\n              '#8E24AA',\n              '#7B1FA2',\n              '#6A1B9A',\n              '#4A148C',\n            ],\n            [\n              '#E8EAF6',\n              '#C5CAE9',\n              '#9FA8DA',\n              '#7986CB',\n              '#5C6BC0',\n              '#3F51B5',\n              '#3949AB',\n              '#303F9F',\n              '#283593',\n              '#1A237E',\n            ],\n            [\n              '#E1F5FE',\n              '#B3E5FC',\n              '#81D4FA',\n              '#4FC3F7',\n              '#29B6F6',\n              '#03A9F4',\n              '#039BE5',\n              '#0288D1',\n              '#0277BD',\n              '#01579B',\n            ],\n            [\n              '#E0F2F1',\n              '#B2DFDB',\n              '#80CBC4',\n              '#4DB6AC',\n              '#26A69A',\n              '#009688',\n              '#00897B',\n              '#00796B',\n              '#00695C',\n              '#004D40',\n            ],\n            [\n              '#F1F8E9',\n              '#DCEDC8',\n              '#C5E1A5',\n              '#AED581',\n              '#9CCC65',\n              '#8BC34A',\n              '#7CB342',\n              '#689F38',\n              '#558B2F',\n              '#33691E',\n            ],\n            [\n              '#FFFDE7',\n              '#FFF9C4',\n              '#FFF59D',\n              '#FFF176',\n              '#FFEE58',\n              '#FFEB3B',\n              '#FDD835',\n              '#FBC02D',\n              '#F9A825',\n              '#F57F17',\n            ],\n            [\n              '#FFF3E0',\n              '#FFE0B2',\n              '#FFCC80',\n              '#FFB74D',\n              '#FFA726',\n              '#FF9800',\n              '#FB8C00',\n              '#F57C00',\n              '#EF6C00',\n              '#E65100',\n            ],\n          ],\n          targetEl: '.pro-picker-target',\n          formatValue(value) {\n            return `rgba(${value.rgba.join(', ')})`;\n          },\n        }\"\n      >\n        <template #media>\n          <i\n            :style=\"`background-color: ${\n              proPickerValue.rgba ? `rgba(${proPickerValue.rgba.join(', ')})` : proPickerValue.hex\n            }`\"\n            class=\"icon demo-list-icon pro-picker-target\"\n          ></i>\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Inline Color Picker</f7-block-title>\n    <f7-block-header>SB Spectrum + HSB Sliders</f7-block-header>\n    <div class=\"block block-strong inset no-padding\">\n      <div v-if=\"inlinePickerValue.rgb\" class=\"padding\">\n        HEX: {{ inlinePickerValue.hex }}<br />\n        Alpha: {{ inlinePickerValue.alpha }}<br />\n        Hue: {{ inlinePickerValue.hue }}<br />\n        RGB: {{ inlinePickerValue.rgb.join(', ') }}<br />\n        HSL: {{ inlinePickerValue.hsl.join(', ') }}<br />\n        HSB: {{ inlinePickerValue.hsb.join(', ') }}<br />\n        RGBA: {{ inlinePickerValue.rgba.join(', ') }}<br />\n        HSLA: {{ inlinePickerValue.hsla.join(', ') }}\n      </div>\n      <div id=\"demo-color-picker-inline\"></div>\n    </div>\n  </f7-page>\n</template>\n<script>\nimport {\n  f7Navbar,\n  f7Page,\n  f7Block,\n  f7BlockTitle,\n  f7BlockHeader,\n  f7List,\n  f7ListInput,\n  f7,\n} from 'framework7-vue';\n\nexport default {\n  components: { f7Navbar, f7Page, f7Block, f7BlockTitle, f7BlockHeader, f7List, f7ListInput },\n  data() {\n    return {\n      wheePickerValue: { hex: '#00ff00' },\n      spectrumPickerValue: { hex: '#ff0000' },\n      hsSpectrumPickerValue: { hex: '#ff0000' },\n      rgbPickerValue: { hex: '#0000ff' },\n      rgbaPickerValue: { hex: '#ff00ff' },\n      hsbPickerValue: { hex: '#00ff00' },\n      rgbBarsPickerValue: { hex: '#0000ff' },\n      rgbSlidersColorsPickerValue: { hex: '#ffff00' },\n      palettePickerValue: { hex: '#FFEBEE' },\n      proPickerValue: { hex: '#00ffff' },\n      inlinePickerValue: { hex: '#77ff66' },\n    };\n  },\n  mounted() {\n    const self = this;\n\n    self.colorPickerInline = f7.colorPicker.create({\n      value: self.inlinePickerValue,\n      containerEl: '#demo-color-picker-inline',\n      modules: ['sb-spectrum', 'hsb-sliders', 'alpha-slider'],\n      on: {\n        change(cp, value) {\n          self.inlinePickerValue = value;\n        },\n      },\n    });\n  },\n  beforeUnmount() {\n    const self = this;\n    self.colorPickerInline.destroy();\n  },\n};\n</script>\n"}