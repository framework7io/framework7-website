{"slug":"store","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Store\" back-link />\n    <f7-block strong inset>\n      <p>\n        Framework7 comes with a built-in lightweight application state management library - Store.\n        It serves as a centralized Store for all the components in an application.\n      </p>\n    </f7-block>\n    <f7-block v-if=\"!users\" class=\"text-align-center\">\n      <f7-button v-if=\"!loading\" fill round @click=\"load\">Load Users</f7-button>\n      <f7-preloader v-else />\n    </f7-block>\n    <f7-list v-if=\"users\" strong inset dividers-ios>\n      <f7-list-item v-for=\"user in users\" :key=\"user\" :title=\"user\" />\n    </f7-list>\n  </f7-page>\n</template>\n<script>\nimport {\n  f7,\n  useStore,\n  f7Page,\n  f7Navbar,\n  f7Block,\n  f7Button,\n  f7Preloader,\n  f7List,\n  f7ListItem,\n} from 'framework7-vue';\n\nexport default {\n  components: { f7Page, f7Navbar, f7Block, f7Button, f7Preloader, f7List, f7ListItem },\n  setup() {\n    // Subscribe to store getters\n    const users = useStore('users');\n    const loading = useStore('usersLoading');\n\n    // Call store action\n    const load = () => f7.store.dispatch('loadUsers');\n\n    return { users, loading, load };\n  },\n};\n</script>\n"}