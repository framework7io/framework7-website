{"slug":"login-screen","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Login Screen\" back-link></f7-navbar>\n    <f7-block>\n      <p>\n        Framework7 comes with ready to use Login Screen layout. It could be used inside of page or\n        inside of popup (Embedded) or as a standalone overlay:\n      </p>\n    </f7-block>\n\n    <!-- example-hidden-start -->\n    <f7-list strong inset>\n      <f7-list-item link=\"/login-screen-page/\" title=\"As Separate Page\"></f7-list-item>\n    </f7-list>\n    <!-- example-hidden-end -->\n\n    <f7-block strong inset>\n      <f7-button round large fill login-screen-open=\".demo-login-screen\">As Overlay</f7-button>\n    </f7-block>\n\n    <f7-block strong inset>\n      <f7-button round large fill @click=\"loginScreenOpened = true\">Open Via Prop Change</f7-button>\n    </f7-block>\n\n    <f7-login-screen v-model:opened=\"loginScreenOpened\" class=\"demo-login-screen\">\n      <f7-page login-screen>\n        <f7-login-screen-title>Framework7</f7-login-screen-title>\n        <f7-list form>\n          <f7-list-input\n            label=\"Username\"\n            type=\"text\"\n            placeholder=\"Your username\"\n            :value=\"username\"\n            @input=\"username = $event.target.value\"\n          ></f7-list-input>\n          <f7-list-input\n            label=\"Password\"\n            type=\"password\"\n            placeholder=\"Your password\"\n            :value=\"password\"\n            @input=\"password = $event.target.value\"\n          ></f7-list-input>\n        </f7-list>\n        <f7-list inset>\n          <f7-list-button @click=\"signIn\">Sign In</f7-list-button>\n          <f7-block-footer\n            >Some text about login information.<br />Lorem ipsum dolor sit amet, consectetur\n            adipiscing elit.</f7-block-footer\n          >\n        </f7-list>\n      </f7-page>\n    </f7-login-screen>\n  </f7-page>\n</template>\n<script>\nimport {\n  f7Navbar,\n  f7Page,\n  f7LoginScreen,\n  f7List,\n  f7ListItem,\n  f7Block,\n  f7Button,\n  f7LoginScreenTitle,\n  f7BlockFooter,\n  f7ListButton,\n  f7ListInput,\n  f7,\n} from 'framework7-vue';\n\nexport default {\n  components: {\n    f7Navbar,\n    f7Page,\n    f7LoginScreen,\n    f7List,\n    f7ListItem,\n    f7Block,\n    f7Button,\n    f7LoginScreenTitle,\n    f7BlockFooter,\n    f7ListButton,\n    f7ListInput,\n  },\n  data() {\n    return { loginScreenOpened: false, username: '', password: '' };\n  },\n  methods: {\n    signIn() {\n      const self = this;\n\n      f7.dialog.alert(`Username: ${self.username}<br>Password: ${self.password}`, () => {\n        f7.loginScreen.close();\n      });\n    },\n  },\n};\n</script>\n"}