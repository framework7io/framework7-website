{"slug":"login-screen","framework":"svelte","source":"<script>\n  import {\n    f7,\n    Navbar,\n    Page,\n    LoginScreen,\n    ListInput,\n    List,\n    ListItem,\n    Block,\n    Button,\n    LoginScreenTitle,\n    BlockFooter,\n    ListButton,\n  } from 'framework7-svelte';\n\n  let loginScreenOpened = false;\n  let username = '';\n  let password = '';\n\n  function signIn() {\n    f7.dialog.alert(`Username: ${username}<br>Password: ${password}`, () => {\n      f7.loginScreen.close();\n    });\n  }\n</script>\n\n<Page>\n  <Navbar title=\"Login Screen\" backLink />\n  <Block strong inset>\n    <p>\n      Framework7 comes with ready to use Login Screen layout. It could be used inside of page or\n      inside of popup (Embedded) or as a standalone overlay:\n    </p>\n  </Block>\n\n  <!-- example-hidden-start -->\n  <List strong inset>\n    <ListItem link=\"/login-screen-page/\" title=\"As Separate Page\" />\n  </List>\n  <!-- example-hidden-end -->\n\n  <Block strong inset>\n    <Button round large fill loginScreenOpen=\".demo-login-screen\">As Overlay</Button>\n  </Block>\n\n  <Block strong inset>\n    <Button round large fill onClick={() => (loginScreenOpened = true)}>\n      Open Via Prop Change\n    </Button>\n  </Block>\n\n  <LoginScreen\n    class=\"demo-login-screen\"\n    opened={loginScreenOpened}\n    onLoginScreenClosed={() => {\n      loginScreenOpened = false;\n      console.log('foobar');\n    }}\n  >\n    <Page loginScreen>\n      <LoginScreenTitle>Framework7</LoginScreenTitle>\n      <List form>\n        <ListInput\n          label=\"Username\"\n          type=\"text\"\n          placeholder=\"Your username\"\n          value={username}\n          onInput={(e) => (username = e.target.value)}\n        />\n        <ListInput\n          label=\"Password\"\n          type=\"password\"\n          placeholder=\"Your password\"\n          value={password}\n          onInput={(e) => (password = e.target.value)}\n        />\n      </List>\n      <List inset>\n        <ListButton onClick={signIn}>Sign In</ListButton>\n      </List>\n      <BlockFooter>\n        Some text about login information.<br />Lorem ipsum dolor sit amet, consectetur adipiscing\n        elit.\n      </BlockFooter>\n    </Page>\n  </LoginScreen>\n</Page>\n"}