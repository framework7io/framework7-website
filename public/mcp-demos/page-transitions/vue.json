{"slug":"page-transitions","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Page Transitions\" back-link></f7-navbar>\n\n    <f7-block>\n      <p>\n        In addition to default theme-specific page transition it is possible to create custom page\n        transition or use one of the additional transition effects:\n      </p>\n    </f7-block>\n\n    <f7-list inset strong dividers-ios>\n      <f7-list-item\n        v-for=\"effect in effects\"\n        :key=\"effect\"\n        :link=\"`/page-transitions/${effect}/`\"\n        :title=\"effect\"\n        :transition=\"effect\"\n      />\n    </f7-list>\n  </f7-page>\n</template>\n<script>\nimport { f7Navbar, f7Page, f7Block, f7List, f7ListItem } from 'framework7-vue';\n\nexport default {\n  components: { f7Navbar, f7Page, f7Block, f7List, f7ListItem },\n  data() {\n    return {\n      effects: [\n        'f7-circle',\n        'f7-cover',\n        'f7-cover-v',\n        'f7-dive',\n        'f7-fade',\n        'f7-flip',\n        'f7-parallax',\n        'f7-push',\n      ],\n    };\n  },\n};\n</script>\n"}