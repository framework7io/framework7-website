{"slug":"navbar","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Navbar\" subtitle=\"Subtitle\" back-link>\n      <f7-nav-right>\n        <f7-link>Right</f7-link>\n      </f7-nav-right>\n    </f7-navbar>\n    <f7-block strong inset>\n      <p>\n        Navbar is a fixed (with Fixed and Through layout types) area at the top of a screen that\n        contains Page title and navigation elements.\n      </p>\n      <p>Navbar has 3 main parts: Left, Title and Right. Each part may contain any HTML content.</p>\n    </f7-block>\n    <f7-list strong inset>\n      <f7-list-item link=\"/navbar-hide-scroll/\" title=\"Hide Navbar On Scroll\"></f7-list-item>\n    </f7-list>\n  </f7-page>\n</template>\n<script>\nimport { f7Navbar, f7Page, f7Block, f7List, f7ListItem, f7NavRight, f7Link } from 'framework7-vue';\n\nexport default {\n  components: { f7Navbar, f7Page, f7Block, f7List, f7ListItem, f7NavRight, f7Link },\n};\n</script>\n"}