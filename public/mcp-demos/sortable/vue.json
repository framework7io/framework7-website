{"slug":"sortable","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Sortable List\" back-link>\n      <f7-nav-right>\n        <f7-link sortable-toggle=\".sortable\">Toggle</f7-link>\n      </f7-nav-right>\n    </f7-navbar>\n\n    <f7-block strong inset>\n      <p>Just click \"Toggle\" button on navigation bar to enable/disable sorting</p>\n    </f7-block>\n    <f7-list strong inset dividers-ios sortable>\n      <f7-list-item title=\"1 Jenna Smith\" after=\"CEO\">\n        <template #media>\n          <f7-icon icon=\"icon-f7\" />\n        </template>\n      </f7-list-item>\n      <f7-list-item title=\"2 John Doe\" after=\"Director\">\n        <template #media>\n          <f7-icon icon=\"icon-f7\" />\n        </template>\n      </f7-list-item>\n      <f7-list-item title=\"3 John Doe\" after=\"Developer\">\n        <template #media>\n          <f7-icon icon=\"icon-f7\" />\n        </template>\n      </f7-list-item>\n      <f7-list-item title=\"4 Aaron Darling\" after=\"Manager\">\n        <template #media>\n          <f7-icon icon=\"icon-f7\" />\n        </template>\n      </f7-list-item>\n      <f7-list-item title=\"5 Calvin Johnson\" after=\"Accounter\">\n        <template #media>\n          <f7-icon icon=\"icon-f7\" />\n        </template>\n      </f7-list-item>\n      <f7-list-item title=\"6 John Smith\" after=\"SEO\">\n        <template #media>\n          <f7-icon icon=\"icon-f7\" />\n        </template>\n      </f7-list-item>\n      <f7-list-item title=\"7 Chloe\" after=\"Manager\">\n        <template #media>\n          <f7-icon icon=\"icon-f7\" />\n        </template>\n      </f7-list-item>\n    </f7-list>\n    <f7-list strong inset dividers-ios media-list sortable>\n      <f7-list-item\n        title=\"Yellow Submarine\"\n        after=\"$15\"\n        subtitle=\"Beatles\"\n        text=\"Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla sagittis tellus ut turpis condimentum, ut dignissim lacus tincidunt. Cras dolor metus