{"slug":"grid","framework":"vue","source":"<template>\n  <f7-page class=\"grid-demo\">\n    <f7-navbar title=\"Grid / Layout\" back-link></f7-navbar>\n    <f7-block>\n      <p>\n        Columns within a row are automatically set to have equal width. Otherwise you can define\n        your column with pourcentage of screen you want.\n      </p>\n    </f7-block>\n    <f7-block-title>Columns with gap</f7-block-title>\n    <f7-block>\n      <div class=\"grid grid-cols-2 grid-gap\">\n        <div>2 cols</div>\n        <div>2 cols</div>\n      </div>\n      <div class=\"grid grid-cols-4 grid-gap\">\n        <div>4 cols</div>\n        <div>4 cols</div>\n        <div>4 cols</div>\n        <div>4 cols</div>\n      </div>\n      <div class=\"grid grid-cols-3 grid-gap\">\n        <div>3 cols</div>\n        <div>3 cols</div>\n        <div>3 cols</div>\n      </div>\n      <div class=\"grid grid-cols-5 grid-gap\">\n        <div>5 cols</div>\n        <div>5 cols</div>\n        <div>5 cols</div>\n        <div>5 cols</div>\n        <div>5 cols</div>\n      </div>\n    </f7-block>\n    <f7-block-title>No gap between columns</f7-block-title>\n    <f7-block>\n      <div class=\"grid grid-cols-2\">\n        <div>2 cols</div>\n        <div>2 cols</div>\n      </div>\n      <div class=\"grid grid-cols-4\">\n        <div>4 cols</div>\n        <div>4 cols</div>\n        <div>4 cols</div>\n        <div>4 cols</div>\n      </div>\n      <div class=\"grid grid-cols-3\">\n        <div>3 cols</div>\n        <div>3 cols</div>\n        <div>3 cols</div>\n      </div>\n      <div class=\"grid grid-cols-5\">\n        <div>5 cols</div>\n        <div>5 cols</div>\n        <div>5 cols</div>\n        <div>5 cols</div>\n        <div>5 cols</div>\n      </div>\n    </f7-block>\n\n    <f7-block-title>Responsive Grid</f7-block-title>\n    <f7-block>\n      <p>Grid cells have different size on Phone/Tablet</p>\n      <div class=\"grid grid-cols-1 medium-grid-cols-2 grid-gap\">\n        <div>1 col / medium 2 cols</div>\n        <div>1 col / medium 2 cols</div>\n      </div>\n      <div class=\"grid grid-cols-2 medium-grid-cols-4 grid-gap\">\n        <div>2 col / medium 4 cols</div>\n        <div>2 col / medium 4 cols</div>\n        <div>2 col / medium 4 cols</div>\n        <div>2 col / medium 4 cols</div>\n      </div>\n    </f7-block>\n  </f7-page>\n</template>\n<script>\nimport { f7Navbar, f7Page, f7BlockTitle, f7Block } from 'framework7-vue';\n\nexport default { components: { f7Navbar, f7Page, f7BlockTitle, f7Block } };\n</script>\n"}