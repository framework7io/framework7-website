{"slug":"panel","framework":"vue","source":"<template>\n  <f7-page id=\"panel-page\">\n    <f7-navbar title=\"Panel / Side panels\" back-link></f7-navbar>\n    <f7-panel id=\"panel-nested\" left cover container-el=\"#panel-page\">\n      <f7-page>\n        <f7-block strong inset>\n          <p>This is page-nested Panel.</p>\n          <p>\n            <f7-link panel-close>Close me</f7-link>\n          </p>\n        </f7-block>\n      </f7-page>\n    </f7-panel>\n    <f7-block strong inset>\n      <p>\n        Framework7 comes with 2 panels (on left and on right), both are optional. You can put\n        absolutely anything inside: data lists, forms, custom content, and even other isolated app\n        view (like in right panel now) with its own dynamic navbar.\n      </p>\n    </f7-block>\n    <f7-block strong inset>\n      <p class=\"grid grid-cols-2 grid-gap\">\n        <f7-button round fill panel-open=\"left\"> Open left panel </f7-button>\n        <f7-button round fill panel-open=\"right\"> Open right panel </f7-button>\n      </p>\n      <p>\n        <f7-button round fill panel-open=\"#panel-nested\"> Open nested panel </f7-button>\n      </p>\n    </f7-block>\n  </f7-page>\n</template>\n<script>\nimport { f7Navbar, f7Page, f7Block, f7Button, f7Link, f7Panel } from 'framework7-vue';\n\nexport default { components: { f7Navbar, f7Page, f7Block, f7Button, f7Link, f7Panel } };\n</script>\n"}