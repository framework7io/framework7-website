{"slug":"pie-chart","framework":"svelte","source":"<script>\n  import { Page, Navbar, BlockTitle, Block, PieChart } from 'framework7-svelte';\n</script>\n\n<Page>\n  <Navbar title=\"Pie Chart\" backLink />\n  <Block strong inset>\n    <p>Framework7 comes with simple to use and fully responsive Pie Chart component.</p>\n    <p>\n      Pie Chart generates SVG layout which makes it also compatible with SSR (server side\n      rendering).\n    </p>\n  </Block>\n  <BlockTitle>Simple Pie Chart</BlockTitle>\n  <Block strong inset>\n    <!-- prettier-ignore -->\n    <PieChart\n      datasets={[\n        {\n          value: 100,\n          color: '#f00',\n        },\n        {\n          value: 200,\n          color: '#0f0',\n        },\n        {\n          value: 300,\n          color: '#00f',\n        },\n      ]}\n    />\n  </Block>\n\n  <BlockTitle>With Tooltip</BlockTitle>\n  <Block strong inset>\n    <!-- prettier-ignore -->\n    <PieChart\n      tooltip\n      datasets={[\n        {\n          label: 'JavaScript',\n          value: 150,\n          color: '#ff0',\n        },\n        {\n          label: 'Vue.js',\n          value: 150,\n          color: '#0f0',\n        },\n        {\n          label: 'TypeScript',\n          value: 400,\n          color: '#00f',\n        },\n      ]}\n    />\n  </Block>\n\n  <BlockTitle>Custom Format Tooltip</BlockTitle>\n  <Block strong inset>\n    <!-- prettier-ignore -->\n    <PieChart\n      tooltip\n      datasets={[\n        {\n          label: 'JavaScript',\n          value: 1000,\n          color: '#ff0',\n        },\n        {\n          label: 'Vue.js',\n          value: 100,\n          color: '#0f0',\n        },\n        {\n          label: 'TypeScript',\n          value: 200,\n          color: '#00f',\n        },\n      ]}\n      formatTooltip={({ color, value, label }) =>\n        `You have <span style=\"color: ${color}\">${value} points</span> for ${label}`\n      }\n    />\n  </Block>\n</Page>\n"}