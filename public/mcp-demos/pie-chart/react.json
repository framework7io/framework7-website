{"slug":"pie-chart","framework":"react","source":"import React from 'react';\nimport { Page, Navbar, BlockTitle, Block, PieChart } from 'framework7-react';\n\nexport default () => {\n  return (\n    <Page>\n      <Navbar title=\"Pie Chart\" backLink />\n      <Block strong inset>\n        <p>Framework7 comes with simple to use and fully responsive Pie Chart component.</p>\n        <p>\n          Pie Chart generates SVG layout which makes it also compatible with SSR (server side\n          rendering).\n        </p>\n      </Block>\n      <BlockTitle>Simple Pie Chart</BlockTitle>\n      <Block strong inset>\n        <PieChart\n          datasets={[\n            { value: 100, color: '#f00' },\n            { value: 200, color: '#0f0' },\n            { value: 300, color: '#00f' },\n          ]}\n        />\n      </Block>\n\n      <BlockTitle>With Tooltip</BlockTitle>\n      <Block strong inset>\n        <PieChart\n          tooltip\n          datasets={[\n            { label: 'JavaScript', value: 150, color: '#ff0' },\n            { label: 'Vue.js', value: 150, color: '#0f0' },\n            { label: 'TypeScript', value: 400, color: '#00f' },\n          ]}\n        />\n      </Block>\n\n      <BlockTitle>Custom Format Tooltip</BlockTitle>\n      <Block strong inset>\n        <PieChart\n          tooltip\n          datasets={[\n            { label: 'JavaScript', value: 1000, color: '#ff0' },\n            { label: 'Vue.js', value: 100, color: '#0f0' },\n            { label: 'TypeScript', value: 200, color: '#00f' },\n          ]}\n          formatTooltip={({ color, value, label }) =>\n            `You have <span style=\"color: ${color}\">${value} points</span> for ${label}`\n          }\n        />\n      </Block>\n    </Page>\n  );\n};\n"}