{"slug":"inputs","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Form Inputs\" back-link></f7-navbar>\n\n    <f7-block-title>Full Layout / Stacked Labels</f7-block-title>\n    <f7-list strong-ios dividers-ios inset-ios>\n      <f7-list-input label=\"Name\" type=\"text\" placeholder=\"Your name\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"Password\" type=\"password\" placeholder=\"Your password\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"E-mail\" type=\"email\" placeholder=\"Your e-mail\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"URL\" type=\"url\" placeholder=\"URL\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"Phone\" type=\"tel\" placeholder=\"Your phone number\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"Gender\" type=\"select\" placeholder=\"Please choose...\">\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n        <option value=\"Male\">Male</option>\n        <option value=\"Female\">Female</option>\n      </f7-list-input>\n\n      <f7-list-input label=\"Birthday\" type=\"date\" placeholder=\"Please choose...\">\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"Date time\" type=\"datetime-local\" placeholder=\"Please choose...\">\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"Range\" :input=\"false\">\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n        <template #input>\n          <f7-range :value=\"50\" :min=\"0\" :max=\"100\" :step=\"1\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"Textarea\" type=\"textarea\" placeholder=\"Bio\">\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"Resizable\" type=\"textarea\" resizable placeholder=\"Bio\">\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Floating Labels</f7-block-title>\n    <f7-list strong-ios dividers-ios inset-ios>\n      <f7-list-input label=\"Name\" floating-label type=\"text\" placeholder=\"Your name\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input\n        label=\"Password\"\n        floating-label\n        type=\"password\"\n        placeholder=\"Your password\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input\n        label=\"E-mail\"\n        floating-label\n        type=\"email\"\n        placeholder=\"Your e-mail\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"URL\" floating-label type=\"url\" placeholder=\"URL\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input\n        label=\"Phone\"\n        floating-label\n        type=\"tel\"\n        placeholder=\"Your phone number\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input label=\"Resizable\" floating-label type=\"textarea\" resizable placeholder=\"Bio\">\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Floating Labels + Outline Inputs</f7-block-title>\n    <f7-list strong-ios dividers-ios inset-ios>\n      <f7-list-input\n        outline\n        label=\"Name\"\n        floating-label\n        type=\"text\"\n        placeholder=\"Your name\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n      <f7-list-input\n        outline\n        label=\"Password\"\n        floating-label\n        type=\"password\"\n        placeholder=\"Your password\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n      <f7-list-input\n        outline\n        label=\"E-mail\"\n        floating-label\n        type=\"email\"\n        placeholder=\"Your e-mail\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n      <f7-list-input outline label=\"URL\" floating-label type=\"url\" placeholder=\"URL\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n      <f7-list-input\n        outline\n        label=\"Phone\"\n        floating-label\n        type=\"tel\"\n        placeholder=\"Your phone number\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n      <f7-list-input\n        outline\n        label=\"Bio\"\n        floating-label\n        type=\"textarea\"\n        resizable\n        placeholder=\"Bio\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Validation + Additional Info</f7-block-title>\n    <f7-list strong-ios dividers-ios inset-ios>\n      <f7-list-input\n        label=\"Name\"\n        type=\"text\"\n        placeholder=\"Your name\"\n        info=\"Default validation\"\n        required\n        validate\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input\n        label=\"Fruit\"\n        type=\"text\"\n        placeholder=\"Type 'apple' or 'banana'\"\n        required\n        validate\n        pattern=\"apple|banana\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n        <template #info>\n          <span>Pattern validation (<b>apple|banana</b>)</span>\n        </template>\n      </f7-list-input>\n\n      <f7-list-input\n        label=\"E-mail\"\n        type=\"email\"\n        placeholder=\"Your e-mail\"\n        info=\"Default e-mail validation\"\n        required\n        validate\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input\n        label=\"URL\"\n        type=\"url\"\n        placeholder=\"Your URL\"\n        info=\"Default URL validation\"\n        required\n        validate\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input\n        label=\"Number\"\n        type=\"text\"\n        placeholder=\"Enter number\"\n        info=\"With custom error message\"\n        error-message=\"Only numbers please!\"\n        required\n        validate\n        pattern=\"[0-9]*\"\n        clear-button\n      >\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Icon + Input</f7-block-title>\n    <f7-list strong-ios dividers-ios inset-ios>\n      <f7-list-input type=\"text\" placeholder=\"Your name\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input type=\"password\" placeholder=\"Your password\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input type=\"email\" placeholder=\"Your e-mail\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n\n      <f7-list-input type=\"url\" placeholder=\"URL\" clear-button>\n        <template #media>\n          <f7-icon icon=\"demo-list-icon\" />\n        </template>\n      </f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Label + Input</f7-block-title>\n    <f7-list strong-ios dividers-ios inset-ios>\n      <f7-list-input label=\"Name\" type=\"text\" placeholder=\"Your name\" clear-button></f7-list-input>\n\n      <f7-list-input\n        label=\"Password\"\n        type=\"password\"\n        placeholder=\"Your password\"\n        clear-button\n      ></f7-list-input>\n\n      <f7-list-input\n        label=\"E-mail\"\n        type=\"email\"\n        placeholder=\"Your e-mail\"\n        clear-button\n      ></f7-list-input>\n\n      <f7-list-input label=\"URL\" type=\"url\" placeholder=\"URL\" clear-button></f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Only Inputs</f7-block-title>\n    <f7-list strong-ios dividers-ios inset-ios>\n      <f7-list-input type=\"text\" placeholder=\"Your name\" clear-button></f7-list-input>\n\n      <f7-list-input type=\"password\" placeholder=\"Your password\" clear-button></f7-list-input>\n\n      <f7-list-input type=\"email\" placeholder=\"Your e-mail\" clear-button></f7-list-input>\n\n      <f7-list-input type=\"url\" placeholder=\"URL\" clear-button></f7-list-input>\n    </f7-list>\n\n    <f7-block-title>Inputs + Additional Info</f7-block-title>\n    <f7-list strong-ios dividers-ios inset-ios>\n      <f7-list-input\n        type=\"text\"\n        placeholder=\"Your name\"\n        info=\"Full name please\"\n        clear-button\n      ></f7-list-input>\n\n      <f7-list-input\n        type=\"password\"\n        placeholder=\"Your password\"\n        info=\"8 characters minimum\"\n        clear-button\n      ></f7-list-input>\n\n      <f7-list-input\n        type=\"email\"\n        placeholder=\"Your e-mail\"\n        info=\"Your work e-mail address\"\n        clear-button\n      ></f7-list-input>\n\n      <f7-list-input\n        type=\"url\"\n        placeholder=\"URL\"\n        info=\"Your website URL\"\n        clear-button\n      ></f7-list-input>\n    </f7-list>\n  </f7-page>\n</template>\n<script>\nimport {\n  f7Navbar,\n  f7Page,\n  f7BlockTitle,\n  f7List,\n  f7Icon,\n  f7ListInput,\n  f7Range,\n} from 'framework7-vue';\n\nexport default {\n  components: { f7Navbar, f7Page, f7BlockTitle, f7List, f7Icon, f7ListInput, f7Range },\n};\n</script>\n"}