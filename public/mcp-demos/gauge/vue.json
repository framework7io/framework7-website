{"slug":"gauge","framework":"vue","source":"<template>\n  <f7-page>\n    <f7-navbar title=\"Gauge\" back-link></f7-navbar>\n    <f7-block strong inset>\n      <p>\n        Framework7 comes with Gauge component. It produces nice looking fully responsive SVG gauges.\n      </p>\n    </f7-block>\n    <f7-block strong inset class=\"text-align-center\">\n      <f7-gauge\n        type=\"circle\"\n        :value=\"gaugeValue\"\n        :size=\"250\"\n        border-color=\"#2196f3\"\n        :border-width=\"10\"\n        :value-text=\"`${gaugeValue * 100}%`\"\n        :value-font-size=\"41\"\n        value-text-color=\"#2196f3\"\n        label-text=\"amount of something\"\n      />\n      <f7-segmented strong round tag=\"p\">\n        <f7-button :active=\"gaugeValue === 0\" @click=\"() => (gaugeValue = 0)\">0%</f7-button>\n        <f7-button :active=\"gaugeValue === 0.25\" @click=\"() => (gaugeValue = 0.25)\">25%</f7-button>\n        <f7-button :active=\"gaugeValue === 0.5\" @click=\"() => (gaugeValue = 0.5)\">50%</f7-button>\n        <f7-button :active=\"gaugeValue === 0.75\" @click=\"() => (gaugeValue = 0.75)\">75%</f7-button>\n        <f7-button :active=\"gaugeValue === 1\" @click=\"() => (gaugeValue = 1)\">100%</f7-button>\n      </f7-segmented>\n    </f7-block>\n\n    <f7-block-title>Circle Gauges</f7-block-title>\n    <f7-block strong inset>\n      <div class=\"grid grid-cols-2 grid-gap\">\n        <div class=\"text-align-center\">\n          <f7-gauge\n            type=\"circle\"\n            :value=\"0.44\"\n            value-text=\"44%\"\n            value-text-color=\"#ff9800\"\n            border-color=\"#ff9800\"\n          />\n        </div>\n        <div class=\"text-align-center\">\n          <f7-gauge\n            type=\"circle\"\n            :value=\"0.12\"\n            value-text=\"$120\"\n            value-text-color=\"#4caf50\"\n            border-color=\"#4caf50\"\n            label-text=\"of $1000 budget\"\n            label-text-color=\"#f44336\"\n            :label-font-weight=\"700\"\n          />\n        </div>\n      </div>\n    </f7-block>\n    <f7-block-title>Semicircle Gauges</f7-block-title>\n    <f7-block strong inset>\n      <div class=\"grid grid-cols-2 grid-gap\">\n        <div class=\"text-align-center\">\n          <f7-gauge\n            type=\"semicircle\"\n            :value=\"0.3\"\n            value-text=\"30%\"\n            value-text-color=\"#f44336\"\n            border-color=\"#f44336\"\n          />\n        </div>\n        <div class=\"text-align-center\">\n          <f7-gauge\n            type=\"semicircle\"\n            :value=\"0.5\"\n            value-text=\"30kg\"\n            value-text-color=\"#e91e63\"\n            border-color=\"#e91e63\"\n            label-text=\"of 60kg total\"\n            label-text-color=\"#333\"\n          />\n        </div>\n      </div>\n    </f7-block>\n    <f7-block-title>Customization</f7-block-title>\n    <f7-block strong inset>\n      <div class=\"grid grid-cols-2 grid-gap\">\n        <div class=\"text-align-center\">\n          <f7-gauge\n            type=\"circle\"\n            :value=\"0.35\"\n            value-text=\"35%\"\n            value-text-color=\"#4caf50\"\n            :value-font-size=\"51\"\n            :value-font-weight=\"700\"\n            :border-width=\"20\"\n            border-color=\"#4caf50\"\n            border-bg-color=\"#ffeb3b\"\n            bg-color=\"#ffeb3b\"\n          />\n        </div>\n        <div class=\"text-align-center\">\n          <f7-gauge\n            type=\"circle\"\n            :value=\"0.67\"\n            value-text=\"$670\"\n            value-text-color=\"#000\"\n            border-color=\"#ff9800\"\n            label-text=\"of $1000 spent\"\n            label-text-color=\"#4caf50\"\n            :label-font-weight=\"800\"\n            :label-font-size=\"12\"\n            :border-width=\"30\"\n          />\n        </div>\n      </div>\n      <br />\n      <div class=\"grid grid-cols-2 grid-gap\">\n        <div class=\"text-align-center\">\n          <f7-gauge\n            type=\"semicircle\"\n            :value=\"0.5\"\n            value-text=\"50%\"\n            value-text-color=\"#ffeb3b\"\n            :value-font-size=\"41\"\n            :value-font-weight=\"700\"\n            :border-width=\"10\"\n            border-color=\"#ffeb3b\"\n            border-bg-color=\"transparent\"\n          />\n        </div>\n        <div class=\"text-align-center\">\n          <f7-gauge\n            type=\"semicircle\"\n            :value=\"0.77\"\n            border-color=\"#ff9800\"\n            label-text=\"$770 spent so far\"\n            label-text-color=\"#ff9800\"\n            :label-font-weight=\"800\"\n            :label-font-size=\"12\"\n            :border-width=\"10\"\n          />\n        </div>\n      </div>\n    </f7-block>\n  </f7-page>\n</template>\n<script>\nimport {\n  f7Page,\n  f7Navbar,\n  f7BlockTitle,\n  f7Block,\n  f7Segmented,\n  f7Button,\n  f7Gauge,\n} from 'framework7-vue';\n\nexport default {\n  components: { f7Page, f7Navbar, f7BlockTitle, f7Block, f7Segmented, f7Button, f7Gauge },\n  data() {\n    return { gaugeValue: 0.5 };\n  },\n};\n</script>\n"}