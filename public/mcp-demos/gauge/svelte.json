{"slug":"gauge","framework":"svelte","source":"<script>\n  import { Navbar, Page, BlockTitle, Block, Segmented, Button, Gauge } from 'framework7-svelte';\n\n  let gaugeValue = $state(0.5);\n</script>\n\n<Page>\n  <Navbar title=\"Gauge\" backLink />\n  <Block strong inset>\n    <p>\n      Framework7 comes with Gauge component. It produces nice looking fully responsive SVG gauges.\n    </p>\n  </Block>\n  <Block strong inset class=\"text-align-center\">\n    <Gauge\n      type=\"circle\"\n      value={gaugeValue}\n      size={250}\n      borderColor=\"#2196f3\"\n      borderWidth={10}\n      valueText={`${gaugeValue * 100}%`}\n      valueFontSize={41}\n      valueTextColor=\"#2196f3\"\n      labelText=\"amount of something\"\n    />\n    <Segmented tag=\"p\" strong round>\n      <Button active={gaugeValue === 0} onclick={() => (gaugeValue = 0)}>0%</Button>\n      <Button active={gaugeValue === 0.25} onclick={() => (gaugeValue = 0.25)}>25%</Button>\n      <Button active={gaugeValue === 0.5} onclick={() => (gaugeValue = 0.5)}>50%</Button>\n      <Button active={gaugeValue === 0.75} onclick={() => (gaugeValue = 0.75)}>75%</Button>\n      <Button active={gaugeValue === 1} onclick={() => (gaugeValue = 1)}>100%</Button>\n    </Segmented>\n  </Block>\n\n  <BlockTitle>Circle Gauges</BlockTitle>\n  <Block strong inset>\n    <div class=\"grid grid-cols-2 grid-gap\">\n      <div class=\"text-align-center\">\n        <Gauge\n          type=\"circle\"\n          value={0.44}\n          valueText=\"44%\"\n          valueTextColor=\"#ff9800\"\n          borderColor=\"#ff9800\"\n        />\n      </div>\n      <div class=\"text-align-center\">\n        <Gauge\n          type=\"circle\"\n          value={0.12}\n          valueText=\"$120\"\n          valueTextColor=\"#4caf50\"\n          borderColor=\"#4caf50\"\n          labelText=\"of $1000 budget\"\n          labelTextColor=\"#f44336\"\n          labelFontWeight={700}\n        />\n      </div>\n    </div>\n  </Block>\n  <BlockTitle>Semicircle Gauges</BlockTitle>\n  <Block strong inset>\n    <div class=\"grid grid-cols-2 grid-gap\">\n      <div class=\"text-align-center\">\n        <Gauge\n          type=\"semicircle\"\n          value={0.3}\n          valueText=\"30%\"\n          valueTextColor=\"#f44336\"\n          borderColor=\"#f44336\"\n        />\n      </div>\n      <div class=\"text-align-center\">\n        <Gauge\n          type=\"semicircle\"\n          value={0.5}\n          valueText=\"30kg\"\n          valueTextColor=\"#e91e63\"\n          borderColor=\"#e91e63\"\n          labelText=\"of 60kg total\"\n          labelTextColor=\"#333\"\n        />\n      </div>\n    </div>\n  </Block>\n  <BlockTitle>Customization</BlockTitle>\n  <Block strong inset>\n    <div class=\"grid grid-cols-2 grid-gap\">\n      <div class=\"text-align-center\">\n        <Gauge\n          type=\"circle\"\n          value={0.35}\n          valueText=\"35%\"\n          valueTextColor=\"#4caf50\"\n          valueFontSize={51}\n          valueFontWeight={700}\n          borderWidth={20}\n          borderColor=\"#4caf50\"\n          borderBgColor=\"#ffeb3b\"\n          bgColor=\"#ffeb3b\"\n        />\n      </div>\n      <div class=\"text-align-center\">\n        <Gauge\n          type=\"circle\"\n          value={0.67}\n          valueText=\"$670\"\n          valueTextColor=\"#000\"\n          borderColor=\"#ff9800\"\n          labelText=\"of $1000 spent\"\n          labelTextColor=\"#4caf50\"\n          labelFontWeight={800}\n          labelFontSize={12}\n          borderWidth={30}\n        />\n      </div>\n    </div>\n    <br />\n    <div class=\"grid grid-cols-2 grid-gap\">\n      <div class=\"text-align-center\">\n        <Gauge\n          type=\"semicircle\"\n          value={0.5}\n          valueText=\"50%\"\n          valueTextColor=\"#ffeb3b\"\n          valueFontSize={41}\n          valueFontWeight={700}\n          borderWidth={10}\n          borderColor=\"#ffeb3b\"\n          borderBgColor=\"transparent\"\n        />\n      </div>\n      <div class=\"text-align-center\">\n        <Gauge\n          type=\"semicircle\"\n          value={0.77}\n          borderColor=\"#ff9800\"\n          labelText=\"$770 spent so far\"\n          labelTextColor=\"#ff9800\"\n          labelFontWeight={800}\n          labelFontSize={12}\n          borderWidth={10}\n        />\n      </div>\n    </div>\n  </Block>\n</Page>\n"}