{"slug":"view-page-transitions","framework":"core","source":"<template>\n  <div id=\"app\">\n    <div class=\"view view-main\">\n      <div class=\"page\">\n        <div class=\"navbar\">\n          <div class=\"navbar-bg\"></div>\n          <div class=\"navbar-inner sliding\">\n            <div class=\"title\">Page Transitions</div>\n          </div>\n        </div>\n        <div class=\"page-content\">\n          <div class=\"list links-list inset list-strong list-dividers-ios\">\n            <ul>\n              <li><a href=\"/page-transitions/f7-circle\" data-transition=\"f7-circle\">f7-circle</a></li>\n              <li><a href=\"/page-transitions/f7-cover\" data-transition=\"f7-cover\">f7-cover</a></li>\n              <li><a href=\"/page-transitions/f7-cover-v\" data-transition=\"f7-cover-v\">f7-cover-v</a></li>\n              <li><a href=\"/page-transitions/f7-dive\" data-transition=\"f7-dive\">f7-dive</a></li>\n              <li><a href=\"/page-transitions/f7-fade\" data-transition=\"f7-fade\">f7-fade</a></li>\n              <li><a href=\"/page-transitions/f7-flip\" data-transition=\"f7-flip\">f7-flip</a></li>\n              <li><a href=\"/page-transitions/f7-parallax\" data-transition=\"f7-parallax\">f7-parallax</a></li>\n              <li><a href=\"/page-transitions/f7-push\" data-transition=\"f7-push\">f7-push</a></li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n<script>\n  export default (props, { $f7, $onMounted }) => {\n    $onMounted(() => {\n      $f7.views.create('.view-main', {\n        routes: [\n          {\n            path: '/page-transitions/:effect',\n            component: (props, { $h }) => {\n\n              return () => $h`\n              <div class=\"page\">\n                <div class=\"navbar\">\n                  <div class=\"navbar-bg\"></div>\n                  <div class=\"navbar-inner sliding\">\n                    <div class=\"left\">\n                      <a href=\"#\" class=\"link back\">\n                        <i class=\"icon icon-back\"></i>\n                      </a>\n                    </div>\n                    <div class=\"title\">${props.effect}</div>\n                  </div>\n                </div>\n                <div class=\"page-content\">\n                  <div class=\"block block-strong inset text-align-center\">\n                    <p>This page was loaded with <b>${props.effect}</b> transition.</p>\n                  </div>\n                </div>\n              </div>\n              `;\n            }\n          },\n        ]\n      })\n    })\n\n    return $render;\n  }\n</script>\n"}