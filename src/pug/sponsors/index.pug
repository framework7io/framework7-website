extends ../_internal-template

block vars
  - var title = 'Framework7 Sponsors';

block content
  div(data-sponsors)
    - var sponsors = getSponsors(getJSONData('sponsors/sponsors.json'));
    h1.text-align-center Framework7 Sponsors
    p.text-align-center.large-text <a href="https://sponsors.nolimits4web.com/" target="_blank">Sponsor Framework7</a> and get your logo and link featured on the website, or support the developer on <a href="https://github.com/sponsors/nolimits4web" target="_blank">GitHub Sponsors</a>. Your support helps keep Framework7 growing!


    h2.text-align-center Gold Sponsor
    .sponsors.sponsors-gold
      if (sponsors.goldSponsor)
        each sponsor in sponsors.goldSponsor
          a.sponsor(href=sponsor.link, target="_blank", rel="sponsored")
            img(src='/i/sponsors/' + sponsor.image, alt=sponsor.title, title=sponsor.title)
    a.sponsor.sponsor-join(href="https://sponsors.nolimits4web.com/", target="_blank") Become Gold Sponsor

    h2.text-align-center Silver Sponsor
    .sponsors.sponsors-silver
      if (sponsors.silverSponsor)
        each sponsor in sponsors.silverSponsor
          a.sponsor(href=sponsor.link, target="_blank", rel="sponsored")
            img(src='/i/sponsors/' + sponsor.image, alt=sponsor.title, title=sponsor.title)
    a.sponsor.sponsor-join(href="https://sponsors.nolimits4web.com/", target="_blank") Become Silver Sponsor

    h2.text-align-center Sponsor
    .sponsors.sponsors-top
      if (sponsors.topSupporter)
        each sponsor in sponsors.topSupporter
          a.sponsor(href=sponsor.link, target="_blank", rel="sponsored")
            img(src='/i/sponsors/' + sponsor.image, alt=sponsor.title, title=sponsor.title)
    a.sponsor.sponsor-join(href="https://sponsors.nolimits4web.com/", target="_blank") Become Top Supporter





