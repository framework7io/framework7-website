          li
            a(href="/mcp/") Framework7 MCP Server
          li
            a(href="/icons/") Framework7 Icons
          li
            a(href="/docs/dom7.html") Dom7
          li.divider
          li
            a(href="/release-notes/") Release Notes
          li.divider
          li
            a(href="https://v8.framework7.io/" target="_blank") Framework7 v8
      li
        a Resources
        ul
          li
            a(href="https://forum.framework7.io" target="_blank") Community Forum
          li
            a(href="/tutorials/") Tutorials
          li
